backend/models/
models/
*.bin
*.safetensors
*.pt
*.pth

# ── Data files ────────────────────────────────────────────────
# Raw scraped data — keep off GitHub (privacy + size)
backend/data/raw/
backend/data/processed/
backend/data/sentiment/
backend/data/aspects/

# Aggregated JSON is safe to commit (no PII) — uncomment to exclude:
# backend/data/aggregated/


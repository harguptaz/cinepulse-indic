# ── YouTube Data API ──────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Movie Configuration ───────────────────────────────────────
MOVIE_NAME=Dhurandhar
MOVIE_RELEASE_DATE=2025-06-05

# ── Pipeline Configuration ────────────────────────────────────
# Set to "cuda" if you have a GPU, otherwise "cpu"
DEVICE=cpu

# Minimum confidence threshold for aspect classification
ASPECT_CONFIDENCE_THRESHOLD=0.45

# Minimum confidence to label as positive/negative (below = neutral)
SENTIMENT_NEUTRAL_THRESHOLD=0.65

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Data Paths ────────────────────────────────────────────────
DATA_DIR=data

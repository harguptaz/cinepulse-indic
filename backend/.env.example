# ── YouTube Data API ──────────────────────────────────────────
# Get your key from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Movie Configuration ───────────────────────────────────────
MOVIE_NAME=Dhurandhar
MOVIE_RELEASE_DATE=2025-06-05

# ── Pipeline Configuration ────────────────────────────────────
# Set to "cuda" if you have an NVIDIA GPU, otherwise "cpu"
DEVICE=cpu

# Batch size for sentiment inference
# GPU recommended: 64   |   CPU recommended: 8
SENTIMENT_BATCH_SIZE=16

# Aspect classification thresholds
ASPECT_CONFIDENCE_THRESHOLD=0.45
SENTIMENT_NEUTRAL_THRESHOLD=0.65

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Data Paths ────────────────────────────────────────────────
DATA_DIR=data
